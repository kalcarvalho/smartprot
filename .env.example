# Copy this file to .env for local Docker usage.
# Do not commit .env.
SMARTPROT_APP_PORT=8081
SMARTPROT_DB_DATABASE=smartprot
SMARTPROT_DB_USERNAME=smartprot
SMARTPROT_DB_PASSWORD=replace-with-local-db-password
SMARTPROT_ADMIN_EMAIL=admin@smartprot.local
SMARTPROT_ADMIN_PASSWORD=replace-with-local-admin-password